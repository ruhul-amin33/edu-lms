<%- include('../partials/header') %>
<div class="container">
  <h2>❓ Question Management</h2>
  <div class="card" style="margin-top:20px;">
    <h3 style="margin-bottom:15px;">নতুন প্রশ্ন যোগ করুন</h3>
    <form method="POST" action="/admin/questions/add">
      <div class="form-group">
        <label>Exam বেছে নিন</label>
        <select name="exam_id" required>
          <% exams.forEach(e => { %>
            <option value="<%= e.id %>"><%= e.title %></option>
          <% }) %>
        </select>
      </div>
      <div class="form-group">
        <label>প্রশ্ন লিখুন</label>
        <textarea name="question_text" required placeholder="প্রশ্নটি লিখুন"></textarea>
      </div>
      <div class="form-group">
        <label>Option A</label>
        <input type="text" name="option_a" required placeholder="Option A">
      </div>
      <div class="form-group">
        <label>Option B</label>
        <input type="text" name="option_b" required placeholder="Option B">
      </div>
      <div class="form-group">
        <label>Option C</label>
        <input type="text" name="option_c" required placeholder="Option C">
      </div>
      <div class="form-group">
        <label>Option D</label>
        <input type="text" name="option_d" required placeholder="Option D">
      </div>
      <div class="form-group">
        <label>সঠিক উত্তর</label>
        <select name="correct_answer" required>
          <option value="A">A</option>
          <option value="B">B</option>
          <option value="C">C</option>
          <option value="D">D</option>
        </select>
      </div>
      <button type="submit" class="btn btn-primary">প্রশ্ন যোগ করুন</button>
    </form>
  </div>
  <div class="card" style="margin-top:20px;">
    <h3 style="margin-bottom:15px;">সকল প্রশ্নসমূহ</h3>
    <table>
      <tr><th>ID</th><th>Exam</th><th>প্রশ্ন</th><th>সঠিক উত্তর</th><th>Action</th></tr>
      <% questions.forEach(q => { %>
      <tr>
        <td><%= q.id %></td>
        <td><%= q.exam_title %></td>
        <td><%= q.question_text.substring(0,60) %>...</td>
        <td><strong><%= q.correct_answer %></strong></td>
        <td>
          <form method="POST" action="/admin/questions/delete/<%= q.id %>" style="display:inline">
            <button class="btn btn-danger btn-sm" onclick="return confirm('Delete করবেন?')">Delete</button>
          </form>
        </td>
      </tr>
      <% }) %>
    </table>
  </div>
</div>
<%- include('../partials/footer') %>