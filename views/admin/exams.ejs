<%- include('../partials/header') %>
<div class="container">
  <h2>📝 Exam Management</h2>
  <div class="card" style="margin-top:20px;">
    <h3 style="margin-bottom:15px;">নতুন Exam তৈরি করুন</h3>
    <form method="POST" action="/admin/exams/add">
      <div class="form-group">
        <label>Exam Title</label>
        <input type="text" name="title" required placeholder="Exam এর নাম">
      </div>
      <div class="form-group">
        <label>Course</label>
        <select name="course_id">
          <% courses.forEach(c => { %>
            <option value="<%= c.id %>"><%= c.title %></option>
          <% }) %>
        </select>
      </div>
      <div class="form-group">
        <label>Time Limit (মিনিট)</label>
        <input type="number" name="time_limit" value="30" min="5">
      </div>
      <div class="form-group">
        <label>Type</label>
        <select name="type">
          <option value="free">Free</option>
          <option value="paid">Paid</option>
        </select>
      </div>
      <button type="submit" class="btn btn-primary">Exam তৈরি করুন</button>
    </form>
  </div>
  <div class="card" style="margin-top:20px;">
    <h3 style="margin-bottom:15px;">সকল Exams</h3>
    <table>
      <tr><th>ID</th><th>Title</th><th>Course</th><th>Time</th><th>Type</th></tr>
      <% exams.forEach(e => { %>
      <tr>
        <td><%= e.id %></td>
        <td><%= e.title %></td>
        <td><%= e.course_title || 'N/A' %></td>
        <td><%= e.time_limit %> মিনিট</td>
        <td><span class="badge badge-<%= e.type %>"><%= e.type %></span></td>
      </tr>
      <% }) %>
    </table>
  </div>
</div>
<%- include('../partials/footer') %>