<%- include('../partials/header') %>
<div class="container">
  <h2>📚 Course Management</h2>
  <div class="card" style="margin-top:20px;">
    <h3 style="margin-bottom:15px;">নতুন Course যোগ করুন</h3>
    <form method="POST" action="/admin/courses/add">
      <div class="form-group">
        <label>Course Title</label>
        <input type="text" name="title" required placeholder="Course এর নাম">
      </div>
      <div class="form-group">
        <label>Description</label>
        <textarea name="description" placeholder="Course সম্পর্কে লিখুন"></textarea>
      </div>
      <div class="form-group">
        <label>Type</label>
        <select name="type">
          <option value="free">Free</option>
          <option value="paid">Paid</option>
        </select>
      </div>
      <div class="form-group">
        <label>Price (Paid হলে)</label>
        <input type="number" name="price" placeholder="0" min="0">
      </div>
      <button type="submit" class="btn btn-primary">Course যোগ করুন</button>
    </form>
  </div>
  <div class="card" style="margin-top:20px;">
    <h3 style="margin-bottom:15px;">সকল Courses</h3>
    <table>
      <tr><th>ID</th><th>Title</th><th>Type</th><th>Price</th><th>Action</th></tr>
      <% courses.forEach(c => { %>
      <tr>
        <td><%= c.id %></td>
        <td><%= c.title %></td>
        <td><span class="badge badge-<%= c.type %>"><%= c.type %></span></td>
        <td>৳<%= c.price %></td>
        <td>
          <form method="POST" action="/admin/courses/delete/<%= c.id %>" style="display:inline">
            <button class="btn btn-danger btn-sm" onclick="return confirm('Delete করবেন?')">Delete</button>
          </form>
        </td>
      </tr>
      <% }) %>
    </table>
  </div>
</div>
<%- include('../partials/footer') %>