<%- include('../partials/header') %>
<div class="container">
  <h2><%= exam.title %></h2>
  <div id="timer">⏱️ <span id="countdown"></span></div>

  <form id="examForm" method="POST" action="/student/exam/<%= exam.id %>/submit">
    <% questions.forEach((q, i) => { %>
    <div class="question-card">
      <p><strong><%= i+1 %>. <%= q.question_text %></strong></p>
      <label><input type="radio" name="q_<%= q.id %>" value="A" required> A. <%= q.option_a %></label>
      <label><input type="radio" name="q_<%= q.id %>" value="B"> B. <%= q.option_b %></label>
      <label><input type="radio" name="q_<%= q.id %>" value="C"> C. <%= q.option_c %></label>
      <label><input type="radio" name="q_<%= q.id %>" value="D"> D. <%= q.option_d %></label>
      <button type="button" class="report-btn" onclick="reportQ(<%= q.id %>)">⚠️ Report করুন</button>
    </div>
    <% }) %>
    <button type="submit" class="btn btn-primary" style="width:100%;padding:15px;font-size:1.1rem;">
      ✅ Submit Exam
    </button>
  </form>
</div>
<script>
  let total = <%= exam.time_limit %> * 60;
  const display = document.getElementById('countdown');
  const interval = setInterval(() => {
    total--;
    const m = Math.floor(total / 60);
    const s = total % 60;
    display.textContent = m + ':' + (s < 10 ? '0' + s : s);
    if (total <= 0) { clearInterval(interval); document.getElementById('examForm').submit(); }
  }, 1000);

  function reportQ(qid) {
    const reason = prompt('কি সমস্যা আছে এই প্রশ্নে?');
    if (!reason) return;
    fetch('/student/report', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ question_id: qid, reason })
    }).then(() => alert('✅ Report পাঠানো হয়েছে!'));
  }
</script>
<%- include('../partials/footer') %>