<%- include('partials/header') %>
<div class="auth-container">
  <h2>🔐 Login</h2>
  <% if(error) { %><div class="error-msg"><%= error %></div><% } %>
  <form method="POST" action="/login">
    <div class="form-group">
      <label>Email</label>
      <input type="email" name="email" required placeholder="আপনার email দিন">
    </div>
    <div class="form-group">
      <label>Password</label>
      <input type="password" name="password" required placeholder="password দিন">
    </div>
    <button type="submit" class="btn btn-primary" style="width:100%">Login করুন</button>
  </form>
  <p style="text-align:center;margin-top:15px;">
    Account নেই? <a href="/register">Register করুন</a>
  </p>
</div>
<%- include('partials/footer') %>